# Server Port
PORT=3000

# Meta WhatsApp Cloud API Credentials
META_API_VERSION=v18.0
META_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
META_ACCESS_TOKEN=your_meta_system_user_access_token
WHATSAPP_VERIFY_TOKEN=your_custom_webhook_validation_token

# Google Cloud Platform Service Account Credentials (for Google Sheets Sync)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@gcp-project.iam.gserviceaccount.com
# Remember to escape newlines (\n) in the private key if stored in a single line env var
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Database Layer (Supabase Postgres)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# AI Engine (Gemini API for Intent Classification)
GEMINI_API_KEY=your_gemini_api_key
